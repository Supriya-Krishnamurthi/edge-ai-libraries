index c9674021..4e297ae0 100644
--- a/devices/igc/igc_main-6.18-ethercat.c
+++ b/devices/igc/igc_main-6.18-ethercat.c
@@ -7630,7 +7630,9 @@ static int __igc_shutdown(struct pci_dev *pdev, bool *enable_wake,
 	igc_ptp_suspend(adapter);
 
 	igc_clear_interrupt_scheme(adapter);
-	rtnl_unlock();
+	if (!get_ecdev(adapter)) {
+		rtnl_unlock();
+	}
 
 	status = rd32(IGC_STATUS);
 	if (status & IGC_STATUS_LU)
diff --git a/devices/igc/igc_main-6.4-ethercat.c b/devices/igc/igc_main-6.4-ethercat.c
index 67001f28..989e4df2 100644
--- a/devices/igc/igc_main-6.4-ethercat.c
+++ b/devices/igc/igc_main-6.4-ethercat.c
@@ -7048,7 +7048,9 @@ static int __igc_shutdown(struct pci_dev *pdev, bool *enable_wake,
 	igc_ptp_suspend(adapter);
 
 	igc_clear_interrupt_scheme(adapter);
-	rtnl_unlock();
+	if (!get_ecdev(adapter)) {
+		rtnl_unlock();
+	}
 
 	status = rd32(IGC_STATUS);
 	if (status & IGC_STATUS_LU)
diff --git a/devices/igc/igc_main-6.6-ethercat.c b/devices/igc/igc_main-6.6-ethercat.c
index 0a92adb8..9c167359 100644
--- a/devices/igc/igc_main-6.6-ethercat.c
+++ b/devices/igc/igc_main-6.6-ethercat.c
@@ -7188,7 +7188,9 @@ static int __igc_shutdown(struct pci_dev *pdev, bool *enable_wake,
 	igc_ptp_suspend(adapter);
 
 	igc_clear_interrupt_scheme(adapter);
-	rtnl_unlock();
+	if (!get_ecdev(adapter)) {
+		rtnl_unlock();
+	}
 
 	status = rd32(IGC_STATUS);
 	if (status & IGC_STATUS_LU)
